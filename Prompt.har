            "text": "{\"pages\":[{\"html\":\"<link rel=\\\"stylesheet\\\" href=\\\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap\\\">\\n<div style=\\\"width: 1080px; height: 1350px; overflow: hidden; position: relative; background-color: #F5F5DC;\\\">\\n    <!-- Background Image - Modified to lighter beige theme -->\\n    <div data-slot-id=\\\"auto-slot-1\\\" class=\\\"image-slot\\\" data-slot-type=\\\"background\\\" data-slot-label=\\\"Cover Background Image\\\" data-search-query=\\\"light beige minimalist office desk aesthetic\\\" style=\\\"position: absolute; top: 0px; left: 0px; width: 100%; height: 100%; z-index: 1; background-color: #F5F5DC; background-image: url('https://storage.mirra.my/media/carousel-images/57831a3f-1ba9-40d7-9581-2af41ef4cd66.jpg');  background-size: cover; background-position: center center; background-repeat: no-repeat;\\\">\\n    </div>\\n\\n    <!-- Gradient Overlay - Adjusted to be lighter/transparent for the beige theme -->\\n    <div style=\\\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 2; background: linear-gradient(to bottom, rgba(245, 245, 220, 0.4) 0%, rgba(245, 245, 220, 0.8) 100%);\\\"></div>\\n\\n    <!-- Content Container -->\\n    <div style=\\\"position: absolute; top: 0px; left: 0px; width: 100%; height: 100%; z-index: 3; padding: 120px 80px; display: flex; flex-direction: column; justify-content: center; align-items: flex-start; transform: translate(47px, 20px);\\\">\\n      \\n      <!-- Tag - Updated border/text color for readability on light background -->\\n      <div style=\\\"display: inline-block; border: 3px solid #1a1a1a; border-radius: 50px; padding: 12px 40px; margin-bottom: 40px;\\\">\\n        <span style=\\\"color: #1a1a1a; font-size: 24px; font-weight: 800; letter-spacing: 2px; font-family: 'Inter', sans-serif;\\\">REALITY CHECK</span>\\n      </div>\\n\\n      <!-- Main Title -->\\n      <h1 style=\\\"font-size: 130px; line-height: 1.1; font-weight: 900; color: #FFCE1F; margin-bottom: 20px; letter-spacing: -2px; text-transform: uppercase; font-family: 'Inter', sans-serif;\\\"><span style=\\\"font-size: 24px; color: rgb(6, 182, 212); font-weight: 500; letter-spacing: -1.5px;\\\">\\n        SETUP</span><br>\\n        <span style=\\\"color: #1a1a1a; font-family: 'Inter', sans-serif;\\\">PORN</span>\\n      </h1>\\n\\n      <!-- Subtitle -->\\n      <h2 style=\\\"font-size: 100px; line-height: 1.1; font-weight: 900; color: #1a1a1a; margin-bottom: 60px; letter-spacing: -2px; font-family: 'Inter', sans-serif;\\\">\\n        NOT REVENUE\\n      </h2>\\n\\n      <!-- Description -->\\n      <p style=\\\"font-size: 32px; color: rgba(26, 26, 26, 0.8); font-weight: 400; max-width: 800px; line-height: 1.5; font-family: 'Inter', sans-serif;\\\">\\n        Why agent frameworks are the ultimate distraction from building a real business.\\n      </p>\\n    </div>\\n\\n    <!-- Overlay Elements -->\\n    <div data-editor-overlay-root=\\\"true\\\" style=\\\"position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 2147483000;\\\">\\n        <span style=\\\"position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); font-size: 32px; font-weight: 600; color: rgb(26, 26, 26); text-align: center; white-space: nowrap; z-index: 10; cursor: pointer; pointer-events: auto; display: inline-block; font-family: 'Inter', sans-serif;\\\">New Text</span>\\n        <div class=\\\"image-slot\\\" data-slot-id=\\\"slot-new-1775339870543\\\" data-slot-type=\\\"main\\\" data-slot-label=\\\"Image\\\" data-search-query=\\\"abstract texture background\\\" style=\\\"position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); width: 300px; height: 200px; background-image: url('https://placehold.co/300x200/e2e8f0/94a3b8?text=Image'); background-size: cover; background-position: center; border-radius: 8px; z-index: 10; pointer-events: auto;\\\"></div>\\n        <div class=\\\"i