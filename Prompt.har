Accent Bar -->\\n    <div style=\\\"position: absolute; bottom: 0; left: 0; width: 100%; height: 20px; background-color: #FFCE1F;\\\"></div>\\n  </div>\",\"title\":\"\",\"pageNumber\":4},{\"html\":\"<link rel=\\\"stylesheet\\\" href=\\\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap\\\">\\n<div style=\\\"width: 1080px; height: 1350px; overflow: hidden; position: relative; background-color: #000000; display: flex; flex-direction: column; align-items: center;\\\">\\n    \\n    <!-- Header Section -->\\n    <div style=\\\"margin-top: 140px; text-align: center; width: 100%; padding: 0 60px;\\\">\\n      <h2 style=\\\"font-size: 80px; font-weight: 800; color: #FFFFFF; margin-bottom: 40px; letter-spacing: -2px; font-family: 'Inter', sans-serif;\\\">FALSE CONSTRAINTS</h2>\\n      <div style=\\\"width: 100%; height: 2px; background-color: #333333; margin-bottom: 80px;\\\"></div>\\n    </div>\\n\\n    <!-- Main Image Content -->\\n    <div data-slot-id=\\\"auto-slot-1\\\" class=\\\"image-slot\\\" data-slot-type=\\\"main\\\" data-slot-label=\\\"Org Chart AI\\\" data-search-query=\\\"corporate org chart abstract ai dark black\\\" style=\\\"width: 900px; height: 550px; background-color: #111111; border-radius: 4px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.5); margin-bottom: 60px; position: relative; background-image: url('https://storage.mirra.my/media/carousel-images/fee6a1c5-f99c-49e0-9eb4-28881f24af12.jpg');  background-size: cover; background-position: center; filter: brightness(0.5) grayscale(0.8);\\\">\\n    </div>\\n\\n    <!-- Text Description -->\\n    <div style=\\\"width: 900px; text-align: center;\\\">\\n      <p style=\\\"font-size: 36px; line-height: 1.6; color: #AAAAAA; font-weight: 400; font-family: 'Inter', sans-serif;\\\">\\n        Human companies look the way they do because of human limitations. Dunbar numbers. Management capacity.<br><br>\\n        <span style=\\\"color: #FFFFFF;\\\">AI has none of these constraints. So why copy paste the org chart?</span>\\n      </p>\\n    </div>\\n\\n    <!-- Bottom Accent Bar -->\\n    <div style=\\\"position: absolute; bottom: 0; left: 0; width: 100%; height: 20px; background-color: #FFCE1F;\\\"></div>\\n  </div>\",\"title\":\"\",\"pageNumber\":5},{\"html\":\"<link rel=\\\"stylesheet\\\" href=\\\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap\\\">\\n<div style=\\\"width: 1080px; height: 1350px; overflow: hidden; position: relative; background-color: #000000;\\\">\\n    \\n    <!-- Background Image -->\\n    <div data-slot-id=\\\"auto-slot-1\\\" class=\\\"image-slot\\\" data-slot-type=\\\"background\\\" data-slot-label=\\\"Wake Up Background\\\" data-search-query=\\\"sunrise clear path forward success dark black\\\" style=\\\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; background-image: url('https://storage.mirra.my/media/carousel-images/1e352dc3-029d-4c69-b737-3b710daad713.jpg');  background-size: cover; background-position: center; filter: brightness(0.3) grayscale(1);\\\">\\n    </div>\\n\\n    <!-- Dark Overlay -->\\n    <div style=\\\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 2; background: rgba(0, 0, 0, 0.9);\\\"></div>\\n\\n    <!-- Content Wrapper -->\\n    <div style=\\\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 3; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 0 80px;\\\">\\n      \\n      <!-- Main Heading -->\\n      <h2 style=\\\"font-size: 90px; font-weight: 800; color: #FFFFFF; margin-bottom: 20px; text-align: center; letter-spacing: -2px; font-family: 'Inter', sans-serif;\\\">\\n        THE ONLY<br>FRAMEWORK\\n      </h2>\\n\\n      <!-- Divider Line -->\\n      <div style=\\\"width: 80%; height: 2px; background-color: rgba(255,255,255,0.1); margin: 60px 0;\\\"></div>\\n\\n      <!-- Quote Icon -->\\n      <div style=\\\"width: 100px; height: 100px; background-color: #FFCE1F; border-radius: 50%; display: flex; justify-content: center; align-items: center; margin-bottom: 50px;\\\">\\n        <svg width=\\\"40\\\" height=\\\"40\\\" viewBox=\\\"0 0 24 24\\\" fill=\\\"#000000\\\">\\n          <path d=\\\"M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H15.017C14.4647 8 14.017 8.44772 14.017 9V11C14.017 11.5523 13.5693 12 13.017 12H12.017V5H22.017V15C22.017 18.3137 19.3307 21 16.017 21H14.017ZM5.0166 21L5.0166 18C5.0166 16.8954 5.91203 16 7.0166 16H10.0166C10.5689 16 11.0166 15.5523 11.0166 15V9C11.0166 8.44772 10.5689 8 10.0166 8H6.0166C5.46432 8 5.0166 8.44772 5.0166 9V11C5.0166 11.5523 4.56889 12 4.0166 12H3.0166V5H13.0166V15C13.0166 18.3137 10.3303 21 7.0166 21H5.0166Z\\\"></path>\\n        </svg>\\n      </div>\\n\\n      <!-- Quote Text -->\\n      <p style=\\\"font-size: 36px; line-height: 1.6; color: #FFFFFF; text-align: center; font-weight: 400; opacity: 0.9; font-family: 'Inter', sans-serif;\\\">\\n        If you're spending more time configuring agents than serving customers, you've already lost.<br><br>\\n        <span style=\\\"color: rgb(255, 206, 31); font-weight: 800; font-family: 'Inter', sans-serif;\\\">SIMPLIFY. SHIP. REPEAT.</span>\\n      </p>\\n    </div>\\n\\n    <!-- Bottom Accent Bar -->\\n    <div style=\\\"position: absolute; bottom: 0; left: 0; width: 100%; height: 20px; background-color: #FFCE1F; z-index: 4;\\\"></div>\\n  </div>\",\"title\":\"\",\"pageNumber\":6}],\"renderedImageUrls\":[],\"thumbnailUrl\":null,\"renderedVideoUrl\":null,\"title\":\"PROJECT_TITLE:...\",\"isPublic\":true,\"viewCount\":0,\"createdAt\":\"2026-04-04 21:56:39.044023+00\",\"updatedAt\":\"2026-04-05 00:35:22.658+00\"}}"
