          "postData": {
            "mimeType": "application/json",
            "text": "{\"pages\":[{\"pageNumber\":1,\"html\":\"<link rel=\\\"stylesheet\\\" href=\\\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap\\\">\\n<div style=\\\"width: 1080px; height: 1350px; overflow: hidden; position: relative; background-color: #F5F5DC;\\\">\\n    <!-- Background Image - Modified to lighter beige theme -->\\n    <div data-slot-id=\\\"auto-slot-1\\\" class=\\\"image-slot\\\" data-slot-type=\\\"background\\\" data-slot-label=\\\"Cover Background Image\\\" data-search-query=\\\"light beige minimalist office desk aesthetic\\\" style=\\\"position: absolute; top: 0px; left: 0px; width: 100%; height: 100%; z-index: 1; background-color: #F5F5DC; background-image: url('https://storage.mirra.my/media/carousel-images/57831a3f-1ba9-40d7-9581-2af41ef4cd66.jpg');  background-size: cover; background-position: center center; background-repeat: no-repeat;\\\">\\n    </div>\\n\\n    <!-- Gradient Overlay - Adjusted to be lighter/transparent for the beige theme -->\\n    <div style=\\\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 2; background: linear-gradient(to bottom, rgba(245, 245, 220, 0.4) 0%, rgba(245, 245, 220, 0.8) 100%);\\\"></div>\\n\\n    <!-- Content Container -->\\n    <div style=\\\"position: absolute; top: 0px; left: 0px; width: 100%; height: 100%; z-index: 3; padding: 120px 80px; display: flex; flex-direction: column; justify-content: center; align-items: flex-start; transform: translate(47px, 20px);\\\">\\n      \\n      <!-- Tag - Updated border/text color for readability on light background -->\\n      <div style=\\\"display: inline-block; border: 3px solid #1a1a1a; border-radius: 50px; padding: 12px 40px; margin-bottom: 40px;\\\">\\n        <span style=\\\"color: #1a1a1a; font-size: 24px; font-weight: 800; letter-spacing: 2px; font-family: 'Inter', sans-serif;\\\">REALITY CHECK</span>\\n      </div>\\n\\n      <!-- Main Title -->\\n      <h1 style=\\\"font-size: 130px; line-height: 1.1; font-weight: 900; color: #FFCE1F; margin-bottom: 20px; letter-spacing: -2px; text-transform: uppercase; font-family: 'Inter', sans-serif;\\\"><span style=\\\"font-size: 24px; color: rgb(6, 182, 212); font-weight: 500; letter-spacing: -1.5px;\\\">\\n        SETUP</span><br>\\n        <span style=\\\"color: #1a1a1a; font-family: 'Inter', sans-serif;\\\">PORN</span>\\n      </h1>\\n\\n      <!-- Subtitle -->\\n      <h2 style=\\\"font-size: 100px; line-height: 1.1; font-weight: 900; color: #1a1a1a; margin-bottom: 60px; letter-spacing: -2px; font-family: 'Inter', sans-serif;\\\">\\n        NOT REVENUE\\n      </h2>\\n\\n      <!-- Description -->\\n      <p style=\\\"font-size: 32px; color: rgba(26, 26, 26, 0.8); font-weight: 400; max-width: 800px; line-height: 1.5; font-family: 'Inter', sans-serif;\\\">\\n        Why agent frameworks are the ultimate distraction from building a real business.\\n      </p>\\n    </div>\\n\\n    <!-- Overlay Elements -->\\n    <div data-editor-overlay-root=\\\"true\\\" style=\\\"position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 2147483000;\\\">\\n        <span style=\\\"position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); font-size: 32px; font-weight: 600; color: rgb(26, 26, 26); text-align: center; white-space: nowrap; z-index: 10; cursor: pointer; pointer-events: auto; display: inline-block; font-family: 'Inter', sans-serif;\\\">New Text</span>\\n        <div class=\\\"image-slot\\\" data-slot-id=\\\"slot-new-1775339870543\\\" data-slot-type=\\\"main\\\" data-slot-label=\\\"Image\\\" data-search-query=\\\"abstract texture background\\\" style=\\\"position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); width: 300px; height: 200px; background-image: url('https://placehold.co/300x200/e2e8f0/94a3b8?text=Image'); background-size: cover; background-position: center; border-radius: 8px; z-index: 10; pointer-events: auto;\\\"></div>\\n        <div class=\\\"image-slot\\\" data-slot-id=\\\"slot-logo-1775339871772\\\" data-slot-type=\\\"logo\\\" data-slot-label=\\\"Logo\\\" style=\\\"position: absolute; left: 20px; top: 20px; width: 120px; height: 60px; background-size: contain; background-repeat: no-repeat; background-position: center; background-image: url('https://placehold.co/120x60/e2e8f0/94a3b8?text=Logo'); z-index: 10; pointer-events: auto;\\\"></div>\\n    </div>\\n</div>\"},{\"pageNumber\":2,\"html\":\"\\n    <link rel=\\\"preconnect\\\" href=\\\"https://fonts.googleapis.com\\\">\\n    <link rel=\\\"preconnect\\\" href=\\\"https://fonts.gstatic.com\\\" crossorigin=\\\"\\\">\\n    <link rel=\\\"preconnect\\\" href=\\\"https://cdn.jsdelivr.net\\\">\\n  \\n<link rel=\\\"stylesheet\\\" href=\\\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap\\\">\\n<div style=\\\"width: 1080px; height: 1350px; overflow: hidden; position: relative; background-color: #F3F3F3; display: flex; flex-direction: column; align-items: center;\\\">\\n    \\n    <!-- Header Section -->\\n    <div style=\\\"margin-top: 140px; text-align: center; width: 100%; padding: 0 60px;\\\">\\n      <h2 style=\\\"font-size: 80px; font-weight: 800; color: #1A1A1A; margin-bottom: 40px; letter-spacing: -2px; font-family: 'Inter', sans-serif;\\\">THE ILLUSION</h2>\\n      <div style=\\\"width: 100%; height: 2px; background-color: #D1D1D1; margin-bottom: 80px;\\\"></div>\\n    </div>\\n\\n    <!-- Main Image Content -->\\n    <div data-slot-id=\\\"auto-slot-1\\\" class=\\\"image-slot\\\" data-slot-type=\\\"main\\\" data-slot-label=\\\"Empty Dashboard\\\" data-search-query=\\\"empty wallet zero balance abstract\\\" style=\\\"width: 900px; height: 550px; background-color: #e2e8f0; border-radius: 4px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.1); margin-bottom: 60px; position: relative; background-image: url('https://storage.mirra.my/media/carousel-images/c8349656-2682-4218-84fb-b3c6b05dc2c2.jpg');  background-size: cover; background-position: center;\\\">\\n    </div>\\n\\n    <!-- Text Description -->\\n    <div style=\\\"width: 900px; text-align: center;\\\">\\n      <p style=\\\"font-size: 36px; line-height: 1.6; color: #4A4A4A; font-weight: 400; font-family: 'Inter', sans-serif;\\\">\\n        Impressive dashboards.<br>\\n        Complex hierarchies.<br>\\n        <strong>Zero revenue.</strong><br><br>\\n        You're not building a business... you're building an expensive hobby.\\n      </p>\\n    </div>\\n\\n    <!-- Bottom Accent Bar -->\\n    <div style=\\\"position: absolute; bottom: 0; left: 0; width: 100%; height: 20px; background-color: #FFCE1F;\\\"></div>\\n  </div>\"},{\"pageNumber\":3,\"html\":\"\\n    <link rel=\\\"preconnect\\\" href=\\\"https://fonts.googleapis.com\\\">\\n    <link rel=\\\"preconnect\\\" href=\\\"https://fonts.gstatic.com\\\" crossorigin=\\\"\\\">\\n    <link rel=\\\"preconnect\\\" href=\\\"https://cdn.jsdelivr.net\\\">\\n  \\n<link rel=\\\"stylesheet\\\" href=\\\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap\\\">\\n<div style=\\\"width: 1080px; height: 1350px; overflow: hidden; position: relative; background-color: #333;\\\">\\n    \\n    <!-- Background Image -->\\n    <div data-slot-id=\\\"auto-slot-1\\\" class=\\\"image-slot\\\" data-slot-type=\\\"background\\\" data-slot-label=\\\"Business Action\\\" data-search-query=\\\"writing business strategy solving problems dark\\\" style=\\\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; background-image: url('https://storage.mirra.my/media/carousel-images/453561d9-7df1-49ac-a67c-0d2902342d27.jpg');  background-size: cover; background-position: center;\\\">\\n    </div>\\n\\n    <!-- Dark Overlay -->\\n    <div style=\\\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 2; background: rgba(0, 0, 0, 0.7);\\\"></div>\\n\\n    <!-- Content Wrapper -->\\n    <div style=\\\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 3; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 0 80px;\\\">\\n      \\n      <!-- Main Heading -->\\n      <h2 style=\\\"font-size: 90px; font-weight: 800; color: #FFFFFF; margin-bottom: 20px; text-align: center; letter-spacing: -2px; font-family: 'Inter', sans-serif;\\\">\\n        WHAT ACTUALLY<br>MAKES MONEY\\n      </h2>\\n\\n      <!-- Divider Line -->\\n      <div style=\\\"width: 80%; height: 2px; background-color: rgba(255,255,255,0.3); margin: 60px 0;\\\"></div>\\n\\n      <!-- Quote Text -->\\n      <p style=\\\"font-size: 36px; line-height: 1.6; color: #FFFFFF; text-align: center; font-weight: 400; opacity: 0.9; font-family: 'Inter', sans-serif;\\\">\\n        Writing better emails.<br>\\n        Creating better offers.<br>\\n        Solving real problems.<br><br>\\n        <span style=\\\"color: rgb(255, 206, 31); font-family: Inter, sans-serif;\\\">NOT: A Telegram bot managing your Hermes agent inside your Paperclip dashboard.</span>\\n      </p>\\n    </div>\\n\\n    <!-- Bottom Accent Bar -->\\n    <div style=\\\"position: absolute; bottom: 0; left: 0; width: 100%; height: 20px; background-color: #FFCE1F; z-index: 4;\\\"></div>\\n  </div>\"},{\"pageNumber\":4,\"html\":\"\\n    <link rel=\\\"preconnect\\\" href=\\\"https://fonts.googleapis.com\\\">\\n    <link rel=\\\"preconnect\\\" href=\\\"https://fonts.gstatic.com\\\" crossorigin=\\\"\\\">\\n    <link rel=\\\"preconnect\\\" href=\\\"https://cdn.jsdelivr.net\\\">\\n  \\n<link rel=\\\"stylesheet\\\" href=\\\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap\\\">\\n<div style=\\\"width: 1080px; height: 1350px; overflow: hidden; position: relative; background-color: #F3F3F3; display: flex; flex-direction: column; align-items: center;\\\">\\n    \\n    <!-- Header Section -->\\n    <div style=\\\"margin-top: 140px; text-align: center; width: 100%; padding: 0 60px;\\\">\\n      <h2 style=\\\"font-size: 80px; font-weight: 800; color: #1A1A1A; margin-bottom: 40px; letter-spacing: -2px; font-family: 'Inter', sans-serif;\\\">THE TRAP</h2>\\n      <div style=\\\"width: 100%; height: 2px; background-color: #D1D1D1; margin-bottom: 60px;\\\"></div>\\n    </div>\\n\\n    <!-- Description Text -->\\n    <div style=\\\"width: 800px; text-align: center; margin-bottom: 80px;\\\">\\n      <p style=\\\"font-size: 34px; line-height: 1.6; color: #4A4A4A; font-weight: 400; font-family: 'Inter', sans-serif;\\\">\\n        Frameworks go viral because they look impressive. Terminal windows. Complex dashboards.<br>\\n        <strong>But impressive вү  profitable.</strong>\\n      </p>\\n    </div>\\n\\n    <!-- Image Grid/Row -->\\n    <div style=\\\"display: flex; gap: 20px; width: 960px; height: 500px; justify-content: center;\\\">\\n      <!-- Left Image -->\\n      <div data-slot-id=\\\"auto-slot-1\\\" class=\\\"image-slot\\\" data-slot-type=\\\"main\\\" data-slot-label=\\\"Terminal Window\\\" data-search-query=\\\"computer terminal code screen\\\" style=\\\"flex: 1; height: 100%; background-color: #e2e8f0; border-radius: 4px; overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.1); position: relative; background-image: url('https://storage.mirra.my/media/carousel-images/53acb4b3-3347-48c6-aaa7-0a1d72f969bc.jpg');  background-size: cover; background-position: center;\\\">\\n      </div>\\n      \\n      <!-- Center Image (Wider) -->\\n      <div data-slot-id=\\\"auto-slot-2\\\" class=\\\"image-slot\\\" data-slot-type=\\\"main\\\" data-slot-label=\\\"Viral Dashboard\\\" data-search-query=\\\"complex data dashboard viral\\\" style=\\\"flex: 1.5; height: 100%; background-color: #e2e8f0; border-radius: 4px; overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.1); position: relative; background-image: url('https://storage.mirra.my/media/carousel-images/fd8394c0-6e54-4c02-bc4a-dfd5eed4ac17.png');  background-size: cover; background-position: center;\\\">\\n      </div>\\n\\n      <!-- Right Image -->\\n      <div data-slot-id=\\\"auto-slot-3\\\" class=\\\"image-slot\\\" data-slot-type=\\\"main\\\" data-slot-label=\\\"Zero Profit\\\" data-search-query=\\\"empty graph going down\\\" style=\\\"flex: 1; height: 100%; background-color: #e2e8f0; border-radius: 4px; overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.1); position: relative; background-image: url('https://storage.mirra.my/media/carousel-images/3d6895dd-8a74-458a-be76-84a4239717ae.jpg');  background-size: cover; background-position: center;\\\">\\n      </div>\\n    </div>\\n\\n    <!-- Bottom Accent Bar -->\\n    <div style=\\\"position: absolute; bottom: 0; left: 0; width: 100%; height: 20px; background-color: #FFCE1F;\\\"></div>\\n  </div>\"},{\"pageNumber\":5,\"html\":\"\\n    <link rel=\\\"preconnect\\\" href=\\\"https://fonts.googleapis.com\\\">\\n    <link rel=\\\"preconnect\\\" href=\\\"https://fonts.gstatic.com\\\" crossorigin=\\\"\\\">\\n    <link rel=\\\"preconnect\\\" href=\\\"https://cdn.jsdelivr.net\\\">\\n  \\n<link rel=\\\"stylesheet\\\" href=\\\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap\\\">\\n<div style=\\\"width: 1080px; height: 1350px; overflow: hidden; position: relative; background-color: #F3F3F3; display: flex; flex-direction: column; align-items: center;\\\">\\n    \\n    <!-- Header Section -->\\n    <div style=\\\"margin-top: 140px; text-align: center; width: 100%; padding: 0 60px;\\\">\\n      <h2 style=\\\"font-size: 80px; font-weight: 800; color: #1A1A1A; margin-bottom: 40px; letter-spacing: -2px; font-family: 'Inter', sans-serif;\\\">FALSE CONSTRAINTS</h2>\\n      <div style=\\\"width: 100%; height: 2px; background-color: #D1D1D1; margin-bottom: 80px;\\\"></div>\\n    </div>\\n\\n    <!-- Main Image Content -->\\n    <div data-slot-id=\\\"auto-slot-1\\\" class=\\\"image-slot\\\" data-slot-type=\\\"main\\\" data-slot-label=\\\"Org Chart AI\\\" data-search-query=\\\"corporate org chart abstract ai\\\" style=\\\"width: 900px; height: 550px; background-color: #e2e8f0; border-radius: 4px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.1); margin-bottom: 60px; position: relative; background-image: url('https://storage.mirra.my/media/carousel-images/3a1cd97d-f219-44f3-9bb8-c13f63b22349.jpg');  background-size: cover; background-position: center;\\\">\\n    </div>\\n\\n    <!-- Text Description -->\\n    <div style=\\\"width: 900px; text-align: center;\\\">\\n      <p style=\\\"font-size: 36px; line-height: 1.6; color: #4A4A4A; font-weight: 400; font-family: 'Inter', sans-serif;\\\">\\n        Human companies look the way they do because of human limitations. Dunbar numbers. Management capacity.<br><br>\\n        AI has none of these constraints. So why copy paste the org chart?\\n      </p>\\n    </div>\\n\\n    <!-- Bottom Accent Bar -->\\n    <div style=\\\"position: absolute; bottom: 0; left: 0; width: 100%; height: 20px; background-color: #FFCE1F;\\\"></div>\\n  </div>\"},{\"pageNumber\":6,\"html\":\"\\n    <link rel=\\\"preconnect\\\" href=\\\"https://fonts.googleapis.com\\\">\\n    <link rel=\\\"preconnect\\\" href=\\\"https://fonts.gstatic.com\\\" crossorigin=\\\"\\\">\\n    <link rel=\\\"preconnect\\\" href=\\\"https://cdn.jsdelivr.net\\\">\\n  \\n<link rel=\\\"stylesheet\\\" href=\\\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap\\\">\\n<div style=\\\"width: 1080px; height: 1350px; overflow: hidden; position: relative; background-color: #333;\\\">\\n    \\n    <!-- Background Image -->\\n    <div data-slot-id=\\\"auto-slot-1\\\" class=\\\"image-slot\\\" data-slot-type=\\\"background\\\" data-slot-label=\\\"Wake Up Background\\\" data-search-query=\\\"sunrise clear path forward success\\\" style=\\\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; background-image: url('https://storage.mirra.my/media/carousel-images/db7209a2-5b5b-4e51-bb06-fc84384bd0ad.jpg');  background-size: cover; background-position: center;\\\">\\n    </div>\\n\\n    <!-- Dark Overlay -->\\n    <div style=\\\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 2; background: rgba(0, 0, 0, 0.8);\\\"></div>\\n\\n    <!-- Content Wrapper -->\\n    <div style=\\\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 3; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 0 80px;\\\">\\n      \\n      <!-- Main Heading -->\\n      <h2 style=\\\"font-size: 90px; font-weight: 800; color: #FFFFFF; margin-bottom: 20px; text-align: center; letter-spacing: -2px; font-family: 'Inter', sans-serif;\\\">\\n        THE ONLY<br>FRAMEWORK\\n      </h2>\\n\\n      <!-- Divider Line -->\\n      <div style=\\\"width: 80%; height: 2px; background-color: rgba(255,255,255,0.3); margin: 60px 0;\\\"></div>\\n\\n      <!-- Quote Icon -->\\n      <div style=\\\"width: 100px; height: 100px; background-color: #FFCE1F; border-radius: 50%; display: flex; justify-content: center; align-items: center; margin-bottom: 50px;\\\">\\n        <svg width=\\\"40\\\" height=\\\"40\\\" viewBox=\\\"0 0 24 24\\\" fill=\\\"#1A1A1A\\\">\\n          <path d=\\\"M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H15.017C14.4647 8 14.017 8.44772 14.017 9V11C14.017 11.5523 13.5693 12 13.017 12H12.017V5H22.017V15C22.017 18.3137 19.3307 21 16.017 21H14.017ZM5.0166 21L5.0166 18C5.0166 16.8954 5.91203 16 7.0166 16H10.0166C10.5689 16 11.0166 15.5523 11.0166 15V9C11.0166 8.44772 10.5689 8 10.0166 8H6.0166C5.46432 8 5.0166 8.44772 5.0166 9V11C5.0166 11.5523 4.56889 12 4.0166 12H3.0166V5H13.0166V15C13.0166 18.3137 10.3303 21 7.0166 21H5.0166Z\\\"></path>\\n        </svg>\\n      </div>\\n\\n      <!-- Quote Text -->\\n      <p style=\\\"font-size: 36px; line-height: 1.6; color: #FFFFFF; text-align: center; font-weight: 400; opacity: 0.9; font-family: 'Inter', sans-serif;\\\">\\n        If you're spending more time configuring agents than serving customers, you've already lost.<br><br>\\n        <span style=\\\"color: rgb(255, 206, 31); font-weight: 800; font-family: Inter, sans-serif;\\\">SIMPLIFY. SHIP. REPEAT.</span>\\n      </p>\\n    </div>\\n\\n    <!-- Bottom Accent Bar -->\\n    <div style=\\\"position: absolute; bottom: 0; left: 0; width: 100%; height: 20px; background-color: #FFCE1F; z-index: 4;\\\"></div>\\n  </div>\"}],\"refinementPrompt\":\"make this balcker\",\"aspectRatio\":\"4:5\",\"pageImages\":[{\"pageNumber\":1,\"url\":\"https://storage.mirra.my/synced-media/carousel/82f8b41c-3966-4128-9a42-8d81e44b3298/1775349279600/page-01.jpeg\"},{\"pageNumber\":2,\"url\":\"https://storage.mirra.my/synced-media/carousel/82f8b41c-3966-4128-9a42-8d81e44b3298/1775349279600/page-02.jpeg\"},{\"pageNumber\":3,\"url\":\"https://storage.mirra.my/synced-media/carousel/82f8b41c-3966-4128-9a42-8d81e44b3298/1775349279600/page-03.jpeg\"},{\"pageNumber\":4,\"url\":\"https://storage.mirra.my/synced-media/carousel/82f8b41c-3966-4128-9a42-8d81e44b3298/1775349279600/page-04.jpeg\"},{\"pageNumber\":5,\"url\":\"https://storage.mirra.my/synced-media/carousel/82f8b41c-3966-4128-9a42-8d81e44b3298/1775349279600/page-05.jpeg\"},{\"pageNumber\":6,\"url\":\"https://storage.mirra.my/synced-media/carousel/82f8b41c-3966-4128-9a42-8d81e44b3298/1775349279600/page-06.jpeg\"}],\"useLightModel\":true}"
