            "text": "{\"generatedPages\":[{\"pageNumber\":1,\"title\":\"\",\"html\":\"<link rel=\\\"stylesheet\\\" href=\\\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap\\\">\\n<div style=\\\"width: 1080px; height: 1350px; overflow: hidden; position: relative; background-color: #000000;\\\">\\n    <!-- Background Image - Darkened and desaturated for the blacker theme -->\\n    <div data-slot-id=\\\"auto-slot-1\\\" class=\\\"image-slot\\\" data-slot-type=\\\"background\\\" data-slot-label=\\\"Cover Background Image\\\" data-search-query=\\\"dark minimalist office desk aesthetic black\\\" style=\\\"position: absolute; top: 0px; left: 0px; width: 100%; height: 100%; z-index: 1; background-color: #000000; background-image: url('https://storage.mirra.my/media/carousel-images/b041f486-2882-4a3f-9a03-1d19891bf85c.jpg');  background-size: cover; background-position: center center; background-repeat: no-repeat; filter: grayscale(1) brightness(0.3);\\\"></div>\\n\\n    <!-- Gradient Overlay - Heavily darkened for \\\"blacker\\\" look -->\\n    <div style=\\\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 2; background: linear-gradient(to bottom, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.95) 100%);\\\"></div>\\n\\n    <!-- Content Container -->\\n    <div style=\\\"position: absolute; top: 0px; left: 0px; width: 100%; height: 100%; z-index: 3; padding: 120px 80px; display: flex; flex-direction: column; justify-content: center; align-items: flex-start; transform: translate(47px, 20px);\\\">\\n      \\n      <!-- Tag - Updated border/text color to white for contrast on black -->\\n      <div style=\\\"display: inline-block; border: 3px solid #FFFFFF; border-radius: 50px; padding: 12px 40px; margin-bottom: 40px;\\\">\\n        <span style=\\\"color: #FFFFFF; font-size: 24px; font-weight: 800; letter-spacing: 2px; font-family: 'Inter', sans-serif;\\\">REALITY CHECK</span>\\n      </div>\\n\\n      <!-- Main Title -->\\n      <h1 style=\\\"font-size: 130px; line-height: 1.1; font-weight: 900; color: #FFCE1F; margin-bottom: 20px; letter-spacing: -2px; text-transform: uppercase; font-family: 'Inter', sans-serif;\\\"><span style=\\\"font-size: 24px; color: rgb(6, 182, 212); font-weight: 500; letter-spacing: -1.5px;\\\">\\n        SETUP</span><br>\\n        <span style=\\\"color: #FFFFFF; font-family: 'Inter', sans-serif;\\\">PORN</span>\\n      </h1>\\n\\n      <!-- Subtitle -->\\n      <h2 style=\\\"font-size: 100px; line-height: 1.1; font-weight: 900; color: #FFFFFF; margin-bottom: 60px; letter-spacing: -2px; font-family: 'Inter', sans-serif;\\\">\\n        NOT REVENUE\\n      </h2>\\n\\n      <!-- Description -->\\n      <p style=\\\"font-size: 32px; color: rgba(255, 255, 255, 0.8); font-weight: 400; max-width: 800px; line-height: 1.5; font-family: 'Inter', sans-serif;\\\">\\n        Why agent frameworks are the ultimate distraction from building a real business.\\n      </p>\\n    </div>\\n\\n    <!-- Overlay Elements -->\\n    <div data-editor-overlay-root=\\\"true\\\" style=\\\"position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 2147483000;\\\">\\n        <span style=\\\"position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); font-size: 32px; font-weight: 600; color: rgb(255, 255, 255); text-align: center; white-space: nowrap; z-index: 10; cursor: pointer; pointer-events: auto; display: inline-block; font-family: 'Inter', sans-serif;\\\">New Text</span>\\n        <div class=\\\"image-slot\\\" data-slot-id=\\\"slot-new-1775339870543\\\" data-slot-type=\\\"main\\\" data-slot-label=\\\"Image\\\" data-search-query=\\\"dark black texture background\\\" style=\\\"position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); width: 300px; height: 200px; background-image: url('https://storage.mirra.my/media/carousel-images/1fc55541-6662-44f8-98b1-120d64012b3e.jpg');  background-size: cover; background-position: center; border-radius: 8px; z-index: 10; pointer-events: auto; filter: brightness(0.5);\\\"></div>\\n        <div class=\\\"image-slot\\\" data-slot-id=\\\"slot-logo-1775339871772\\\" data-slot-type=\\\"logo\\\" data-slot-label=\\\"Logo\\\" style=\\\"position: absolute; left: 20px; top: 20px; width: 120px; height: 60px; background-size: contain; background-repeat: no-repeat; background-position: center; background-image: url('https://placehold.co/120x60/e2e8f0/94a3b8?text=Logo'); z-index: 10; pointer-events: auto; filter: invert(1);\\\"></div>\\n    </div>\\n</div>\"},{\"pageNumber\":2,\"title\":\"\",\"html\":\"<link rel=\\\"stylesheet\\\" href=\\\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap\\\">\\n<div style=\\\"width: 1080px; height: 1350px; overflow: hidden; position: relative; background-color: #000000; display: flex; flex-direction: column; align-items: center;\\\">\\n    \\n    <!-- Header Section -->\\n    <div style=\\\"margin-top: 140px; text-align: center; width: 100%; padding: 0 60px;\\\">\\n      <h2 style=\\\"font-size: 80px; font-weight: 800; color: #FFFFFF; margin-bottom: 40px; letter-spacing: -2px; font-family: 'Inter', sans-serif;\\\">THE ILLUSION</h2>\\n      <div style=\\\"width: 100%; height: 2px; background-color: #333333; margin-bottom: 80px;\\\"></div>\\n    </div>\\n\\n    <!-- Main Image Content -->\\n    <div data-slot-id=\\\"auto-slot-1\\\" class=\\\"image-slot\\\" data-slot-type=\\\"main\\\" data-slot-label=\\\"Empty Dashboard\\\" data-search-query=\\\"empty wallet zero balance abstract dark black\\\" style=\\\"width: 900px; height: 550px; background-color: #111111; border-radius: 4px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.5); margin-bottom: 60px; position: relative; background-image: url('https://storage.mirra.my/media/carousel-images/5c6dd781-0b9e-4c18-a577-8c80a380faa4.jpg');  background-size: cover; background-position: center; filter: brightness(0.6) grayscale(0.5);\\\">\\n    </div>\\n\\n    <!-- Text Description -->\\n    <div style=\\\"width: 900px; text-align: center;\\\">\\n      <p style=\\\"font-size: 36px; line-height: 1.6; color: #AAAAAA; font-weight: 400; font-family: 'Inter', sans-serif;\\\">\\n        Impressive dashboards.<br>\\n        Complex hierarchies.<br>\\n        <strong style=\\\"color: #FFFFFF;\\\">Zero revenue.</strong><br><br>\\n        You're not building a business... you're building an expensive hobby.\\n      </p>\\n    </div>\\n\\n    <!-- Bottom Accent Bar -->\\n    <div style=\\\"position: absolute; bottom: 0; left: 0; width: 100%; height: 20px; background-color: #FFCE1F;\\\"></div>\\n  </div>\"},{\"pageNumber\":3,\"title\":\"\",\"html\":\"<link rel=\\\"stylesheet\\\" href=\\\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap\\\">\\n<div style=\\\"width: 1080px; height: 1350px; overflow: hidden; position: relative; background-color: #000000;\\\">\\n    \\n    <!-- Background Image -->\\n    <div data-slot-id=\\\"auto-slot-1\\\" class=\\\"image-slot\\\" data-slot-type=\\\"background\\\" data-slot-label=\\\"Business Action\\\" data-search-query=\\\"writing business strategy solving problems dark black background\\\" style=\\\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; background-image: url('https://storage.mirra.my/media/carousel-images/93b3a312-2d3f-4ea7-96c5-0d3d306abcc7.webp');  background-size: cover; background-position: center; filter: brightness(0.4) grayscale(1);\\\">\\n    </div>\\n\\n    <!-- Dark Overlay -->\\n    <div style=\\\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 2; background: rgba(0, 0, 0, 0.85);\\\"></div>\\n\\n    <!-- Content Wrapper -->\\n    <div style=\\\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 3; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 0 80px;\\\">\\n      \\n      <!-- Main Heading -->\\n      <h2 style=\\\"font-size: 90px; font-weight: 800; color: #FFFFFF; margin-bottom: 20px; text-align: center; letter-spacing: -2px; font-family: 'Inter', sans-serif;\\\">\\n        WHAT ACTUALLY<br>MAKES MONEY\\n      </h2>\\n\\n      <!-- Divider Line -->\\n      <div style=\\\"width: 80%; height: 2px; background-color: rgba(255,255,255,0.1); margin: 60px 0;\\\"></div>\\n\\n      <!-- Quote Text -->\\n      <p style=\\\"font-size: 36px; line-height: 1.6; color: #FFFFFF; text-align: center; font-weight: 400; opacity: 0.9; font-family: 'Inter', sans-serif;\\\">\\n        Writing better emails.<br>\\n        Creating better offers.<br>\\n        Solving real problems.<br><br>\\n        <span style=\\\"color: rgb(255, 206, 31); font-family: 'Inter', sans-serif;\\\">NOT: A Telegram bot managing your Hermes agent inside your Paperclip dashboard.</span>\\n      </p>\\n    </div>\\n\\n    <!-- Bottom Accent Bar -->\\n    <div style=\\\"position: absolute; bottom: 0; left: 0; width: 100%; height: 20px; background-color: #FFCE1F; z-index: 4;\\\"></div>\\n  </div>\"},{\"pageNumber\":4,\"title\":\"\",\"html\":\"<link rel=\\\"stylesheet\\\" href=\\\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap\\\">\\n<div style=\\\"width: 1080px; height: 1350px; overflow: hidden; position: relative; background-color: #000000; display: flex; flex-direction: column; align-items: center;\\\">\\n    \\n    <!-- Header Section -->\\n    <div style=\\\"margin-top: 140px; text-align: center; width: 100%; padding: 0 60px;\\\">\\n      <h2 style=\\\"font-size: 80px; font-weight: 800; color: #FFFFFF; margin-bottom: 40px; letter-spacing: -2px; font-family: 'Inter', sans-serif;\\\">THE TRAP</h2>\\n      <div style=\\\"width: 100%; height: 2px; background-color: #333333; margin-bottom: 60px;\\\"></div>\\n    </div>\\n\\n    <!-- Description Text -->\\n    <div style=\\\"width: 800px; text-align: center; margin-bottom: 80px;\\\">\\n      <p style=\\\"font-size: 34px; line-height: 1.6; color: #AAAAAA; font-weight: 400; font-family: 'Inter', sans-serif;\\\">\\n        Frameworks go viral because they look impressive. Terminal windows. Complex dashboards.<br>\\n        <strong style=\\\"color: #FFFFFF;\\\">But impressive вү  profitable.</strong>\\n      </p>\\n    </div>\\n\\n    <!-- Image Grid/Row -->\\n    <div style=\\\"display: flex; gap: 20px; width: 960px; height: 500px; justify-content: center;\\\">\\n      <!-- Left Image -->\\n      <div data-slot-id=\\\"auto-slot-1\\\" class=\\\"image-slot\\\" data-slot-type=\\\"main\\\" data-slot-label=\\\"Terminal Window\\\" data-search-query=\\\"computer terminal code screen black dark\\\" style=\\\"flex: 1; height: 100%; background-color: #111111; border-radius: 4px; overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.5); position: relative; background-image: url('https://storage.mirra.my/media/carousel-images/c260475e-8e47-4c0c-93f5-62547de5849b.jpg');  background-size: cover; background-position: center; filter: brightness(0.6) grayscale(0.5);\\\">\\n      </div>\\n      \\n      <!-- Center Image (Wider) -->\\n      <div data-slot-id=\\\"auto-slot-2\\\" class=\\\"image-slot\\\" data-slot-type=\\\"main\\\" data-slot-label=\\\"Viral Dashboard\\\" data-search-query=\\\"complex data dashboard viral dark theme black\\\" style=\\\"flex: 1.5; height: 100%; background-color: #111111; border-radius: 4px; overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.5); position: relative; background-image: url('https://storage.mirra.my/media/carousel-images/2080e1be-afc0-4727-bde1-1b6246fd8531.jpg');  background-size: cover; background-position: center; filter: brightness(0.5);\\\">\\n      </div>\\n\\n      <!-- Right Image -->\\n      <div data-slot-id=\\\"auto-slot-3\\\" class=\\\"image-slot\\\" data-slot-type=\\\"main\\\" data-slot-label=\\\"Zero Profit\\\" data-search-query=\\\"empty graph going down dark aesthetic black\\\" style=\\\"flex: 1; height: 100%; background-color: #111111; border-radius: 4px; overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.5); position: relative; background-image: url('https://storage.mirra.my/media/carousel-images/20dd1046-3b61-4b65-a668-1822d8ea2947.jpg');  background-size: cover; background-position: center; filter: brightness(0.6) grayscale(0.5);\\\">\\n      </div>\\n    </div>\\n\\n    <!-- Bottom Accent Bar -->\\n    <div style=\\\"position: absolute; bottom: 0; left: 0; width: 100%; height: 20px; background-color: #FFCE1F;\\\"></div>\\n  </div>\"},{\"pageNumber\":5,\"title\":\"\",\"html\":\"<link rel=\\\"stylesheet\\\" href=\\\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap\\\">\\n<div style=\\\"width: 1080px; height: 1350px; overflow: hidden; position: relative; background-color: #000000; display: flex; flex-direction: column; align-items: center;\\\">\\n    \\n    <!-- Header Section -->\\n    <div style=\\\"margin-top: 140px; text-align: center; width: 100%; padding: 0 60px;\\\">\\n      <h2 style=\\\"font-size: 80px; font-weight: 800; color: #FFFFFF; margin-bottom: 40px; letter-spacing: -2px; font-family: 'Inter', sans-serif;\\\">FALSE CONSTRAINTS</h2>\\n      <div style=\\\"width: 100%; height: 2px; background-color: #333333; margin-bottom: 80px;\\\"></div>\\n    </div>\\n\\n    <!-- Main Image Content -->\\n    <div data-slot-id=\\\"auto-slot-1\\\" class=\\\"image-slot\\\" data-slot-type=\\\"main\\\" data-slot-label=\\\"Org Chart AI\\\" data-search-query=\\\"corporate org chart abstract ai dark black\\\" style=\\\"width: 900px; height: 550px; background-color: #111111; border-radius: 4px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.5); margin-bottom: 60px; position: relative; background-image: url('https://storage.mirra.my/media/carousel-images/fee6a1c5-f99c-49e0-9eb4-28881f24af12.jpg');  background-size: cover; background-position: center; filter: brightness(0.5) grayscale(0.8);\\\">\\n    </div>\\n\\n    <!-- Text Description -->\\n    <div style=\\\"width: 900px; text-align: center;\\\">\\n      <p style=\\\"font-size: 36px; line-height: 1.6; color: #AAAAAA; font-weight: 400; font-family: 'Inter', sans-serif;\\\">\\n        Human companies look the way they do because of human limitations. Dunbar numbers. Management capacity.<br><br>\\n        <span style=\\\"color: #FFFFFF;\\\">AI has none of these constraints. So why copy paste the org chart?</span>\\n      </p>\\n    </div>\\n\\n    <!-- Bottom Accent Bar -->\\n    <div style=\\\"position: absolute; bottom: 0; left: 0; width: 100%; height: 20px; background-color: #FFCE1F;\\\"></div>\\n  </div>\"},{\"pageNumber\":6,\"title\":\"\",\"html\":\"<link rel=\\\"stylesheet\\\" href=\\\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap\\\">\\n<div style=\\\"width: 1080px; height: 1350px; overflow: hidden; position: relative; background-color: #000000;\\\">\\n    \\n    <!-- Background Image -->\\n    <div data-slot-id=\\\"auto-slot-1\\\" class=\\\"image-slot\\\" data-slot-type=\\\"background\\\" data-slot-label=\\\"Wake Up Background\\\" data-search-query=\\\"sunrise clear path forward success dark black\\\" style=\\\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; background-image: url('https://storage.mirra.my/media/carousel-images/1e352dc3-029d-4c69-b737-3b710daad713.jpg');  background-size: cover; background-position: center; filter: brightness(0.3) grayscale(1);\\\">\\n    </div>\\n\\n    <!-- Dark Overlay -->\\n    <div style=\\\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 2; background: rgba(0, 0, 0, 0.9);\\\"></div>\\n\\n    <!-- Content Wrapper -->\\n    <div style=\\\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 3; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 0 80px;\\\">\\n      \\n      <!-- Main Heading -->\\n      <h2 style=\\\"font-size: 90px; font-weight: 800; color: #FFFFFF; margin-bottom: 20px; text-align: center; letter-spacing: -2px; font-family: 'Inter', sans-serif;\\\">\\n        THE ONLY<br>FRAMEWORK\\n      </h2>\\n\\n      <!-- Divider Line -->\\n      <div style=\\\"width: 80%; height: 2px; background-color: rgba(255,255,255,0.1); margin: 60px 0;\\\"></div>\\n\\n      <!-- Quote Icon -->\\n      <div style=\\\"width: 100px; height: 100px; background-color: #FFCE1F; border-radius: 50%; display: flex; justify-content: center; align-items: center; margin-bottom: 50px;\\\">\\n        <svg width=\\\"40\\\" height=\\\"40\\\" viewBox=\\\"0 0 24 24\\\" fill=\\\"#000000\\\">\\n          <path d=\\\"M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H15.017C14.4647 8 14.017 8.44772 14.017 9V11C14.017 11.5523 13.5693 12 13.017 12H12.017V5H22.017V15C22.017 18.3137 19.3307 21 16.017 21H14.017ZM5.0166 21L5.0166 18C5.0166 16.8954 5.91203 16 7.0166 16H10.0166C10.5689 16 11.0166 15.5523 11.0166 15V9C11.0166 8.44772 10.5689 8 10.0166 8H6.0166C5.46432 8 5.0166 8.44772 5.0166 9V11C5.0166 11.5523 4.56889 12 4.0166 12H3.0166V5H13.0166V15C13.0166 18.3137 10.3303 21 7.0166 21H5.0166Z\\\"></path>\\n        </svg>\\n      </div>\\n\\n      <!-- Quote Text -->\\n      <p style=\\\"font-size: 36px; line-height: 1.6; color: #FFFFFF; text-align: center; font-weight: 400; opacity: 0.9; font-family: 'Inter', sans-serif;\\\">\\n        If you're spending more time configuring agents than serving customers, you've already lost.<br><br>\\n        <span style=\\\"color: rgb(255, 206, 31); font-weight: 800; font-family: 'Inter', sans-serif;\\\">SIMPLIFY. SHIP. REPEAT.</span>\\n      </p>\\n    </div>\\n\\n    <!-- Bottom Accent Bar -->\\n    <div style=\\\"position: absolute; bottom: 0; left: 0; width: 100%; height: 20px; background-color: #FFCE1F; z-index: 4;\\\"></div>\\n  </div>\"}],\"aspectRatio\":\"4:5\"}"
